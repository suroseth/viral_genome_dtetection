rule align_reads:
    input:
        r1=config["trimmed_reads"] + "/{sample}_1_val_1.fq.gz",
        r2=config["trimmed_reads"] + "/{sample}_2_val_2.fq.gz"
    output:
        config["alignment_out"] + "/{sample}.aligned.sorted.bam"
    threads: 12
    shell:
        """
        hisat2 -x {config[hisat2_index]} \
        -1 {input.r1} \
        -2 {input.r2} \
        -p {threads} | \
        samtools sort -@ {threads} -O BAM -o {output}
        """

rule remove_human_reads:
    input:
        config["alignment_out"] + "/{sample}.aligned.sorted.bam"
    output:
        config["nohuman_reads"] + "/{sample}.unmapped.bam"
    shell:
        """
        samtools view -b -f 12 -F 256 {input} -o {output}
        """


rule convert_bam_fastq:
    input:
        bam=config["nohuman_reads"] + "/{sample}.unmapped.bam"
    output:
        r1 = config["nohuman_fastq"] + "/{sample}_1.fastq",
        r2 = config["nohuman_fastq"] + "/{sample}_2.fastq"
    shell:
        """
        bedtools bamtofastq -i {input} -fq {output.r1} -fq2 {output.r2}
        """


rule taxonomic_classification:
    input:
        r1 = config["nohuman_fastq"] + "/{sample}_1.fastq"
        r2 = config["nohuman_fastq"] + "/{sample}_2.fastq"
    output:
        r1 = config["viral_report"] + "/{sample}_report.txt"
        r2 = config["viral_report"] + "/{sample}_output.txt"
    shell:
        """
        kraken2 \
        --db kraken2_viral_db \
        --paired {input.r1} {input.r2} \
        --report {output.r1} \
        --output {output.r2}
        """


rule viral_read_extraction:
    input:
        r1 = config["nohuman_fastq"] + "/{sample}_1.fastq",
        r2 = config["nohuman_fastq"] + "/{sample}_2.fastq",
        r3 = config["viral_report"] + "/{sample}_report.txt"
    output:
        r1 = config["viral_reads"] + "/{sample}_1.fastq",
        r2 = config["viral_reads"] + "/{sample}_2.fastq"

    shell:
        """
        extract_kraken_reads.py \
        -k {input.r3} \
        -s {input.r1} \
        -s2 {input.r2} \
        -t 10239 \
        -o {output.r1} \
        -o2 {output.r2}
        """




