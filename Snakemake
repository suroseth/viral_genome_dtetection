hell.executable("/bin/bash")

configfile: "config.yaml"


SAMPLES = [line.strip() for line in open("samplesheet_sub3.txt")]


rule all:
    input:
        expand(config["viral_reads"] + "/{sample}_1.fastq", sample=SAMPLES),
        expand(config["viral_reads"] + "/{sample}_2.fastq", sample=SAMPLES),
        config["qc"] + "/multiqc_report.html"

rule fastqc_pretrim:
    input:
        r1=config["merged_reads"] + "/{sample}_1.fastq.gz",
        r2=config["merged_reads"] + "/{sample}_2.fastq.gz"
    output:
        r1=config["qc"] + "/{sample}_1_fastqc.html",
        r2=config["qc"] + "/{sample}_2_fastqc.html"
    threads: 2
    shell:
        """
        fastqc -t {threads} {input.r1} {input.r2} -o {config["qc"]}
        """


rule multiqc_pretrim:
    input:
        expand(config["qc"] + "/{sample}_1_fastqc.html", sample=SAMPLES),
        expand(config["qc"] + "/{sample}_2_fastqc.html", sample=SAMPLES)
    output:
        config["qc"] + "/multiqc_report.html"
    shell:
        """
        multiqc {config["qc"]} -o {config["qc"]}
        """


rule trim_reads:
    input:
        r1=config["merged_reads"] + "/{sample}_1.fastq.gz",
        r2=config["merged_reads"] + "/{sample}_2.fastq.gz"
    output:
        r1=config["trimmed_reads"] + "/{sample}_1_val_1.fq.gz",
        r2=config["trimmed_reads"] + "/{sample}_2_val_2.fq.gz"
    threads: 4
    shell:
        """
        trim_galore --paired --quality 30 --length 36 --cores {threads} \
        -o {config["trimmed_reads"]} \
        {input.r1} {input.r2}
        """


